# PacketLens 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ─── 内置 AI Provider 配置 ───
# 此处配置的 Provider 在 UI 中只读不可修改
# 如需使用多个模型，请在应用设置中手动添加
AI_NAME=
# 协议类型：openai（默认，兼容大多数中转）或 anthropic（Claude 原生 / Anthropic 协议中转）
AI_PROVIDER_TYPE=openai
AI_API_BASE=
AI_API_KEY=your-api-key-here
AI_MODEL=
AI_CONTEXT_WINDOW=200000
AI_MAX_TOKENS=131072
AI_TEMPERATURE=0.3
AI_MAX_INPUT_CHARS=200000
AI_TIMEOUT=120
AI_MAX_CONCURRENCY=3
AI_MAX_LAYER2_FLOWS=10
AI_PACKETS_PER_FLOW_LAYER1=5
